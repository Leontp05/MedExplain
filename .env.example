# Application
APP_ENV=development
APP_NAME=MedExplain AI
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
DEBUG=false

# Database (PostgreSQL in production; SQLite for local dev)
# Windows: use %LOCALAPPDATA% — SQLite journal files often fail on some D: drives
DATABASE_URL=sqlite+aiosqlite:///%LOCALAPPDATA%/MedExplain/data/medical.db

# Session / CSRF
SESSION_EXPIRE_MINUTES=60
CSRF_SECRET=change-me-csrf-secret-key

# File storage
STORAGE_PATH=/app/storage
ENCRYPTION_KEY=change-me-32-byte-base64-fernet-key
MAX_UPLOAD_SIZE_MB=10
AUTO_DELETE_HOURS=24

# ClamAV (optional; set CLAMAV_ENABLED=false to skip in dev)
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# AI provider (openai | gemini | anthropic | groq)
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Rate limiting
RATE_LIMIT_UPLOADS=10/hour
RATE_LIMIT_AI=30/hour
RATE_LIMIT_LOGIN=5/minute

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost

# Frontend URL (for CSRF/cookies)
FRONTEND_URL=http://localhost:5173
